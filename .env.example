# GitHub 동기화 설정
# 이 파일을 복사해서 .env 로 저장하고 값을 채워주세요

# GitHub Personal Access Token (repo 권한 필요)
# https://github.com/settings/tokens 에서 발급
GITHUB_TOKEN=ghp_여기에_토큰_입력

# GitHub 저장소 (owner/repo 형식)
GITHUB_REPO=김지원/stocks-data

# 브랜치 이름 (기본값: main)
GITHUB_BRANCH=main

# 저장소 내 파일 경로 (기본값: data/portfolio_data.json)
GITHUB_FILE_PATH=data/portfolio_data.json

# 한국투자증권 OpenAPI
KIS_APP_KEY=여기에_APP_KEY
KIS_APP_SECRET=여기에_APP_SECRET
# 기존 이름도 지원합니다.
MYAPP=여기에_APP_KEY
MYSEC=여기에_APP_SECRET
KIS_ACCOUNT_NO=12345678
KIS_ACCOUNT_PRODUCT_CODE=01
KIS_MOCK=true

# 실주문은 이 값과 대시보드 dry_run 해제가 모두 필요합니다.
KIS_ENABLE_LIVE_ORDERS=false

# Claude 전략 분석 (선택)
ANTHROPIC_API_KEY=sk-ant-여기에_키_입력
ANTHROPIC_MODEL=claude-sonnet-4-20250514
